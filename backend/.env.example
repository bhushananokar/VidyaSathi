# ── AI API Keys ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Providers: Supabase (supabase.com), Neon (neon.tech), Railway (railway.app)
# Format:    postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# ── Upstash Redis ──────────────────────────────────────────────────────────────
# Get from: upstash.com → Create Database → copy "Redis URL"
# Must use rediss:// (with double-s, TLS) for Upstash
REDIS_URL=rediss://default:password@xxxx.upstash.io:6379

# ── ChromaDB Cloud ─────────────────────────────────────────────────────────────
# Get from: trychroma.com → Create cluster → copy credentials
# For self-hosted on Railway/Render: CHROMA_HOST=your-instance.railway.app,
#   CHROMA_PORT=8000, CHROMA_SSL=false, leave CHROMA_TENANT/DATABASE as defaults
CHROMA_HOST=api.trychroma.com
CHROMA_PORT=443
CHROMA_SSL=true
CHROMA_API_KEY=your_chroma_api_key_here
CHROMA_TENANT=your_tenant_id_here
CHROMA_DATABASE=default_database

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://your-frontend.vercel.app,https://your-domain.com

# ── Gemini Models (optional overrides) ────────────────────────────────────────
GEMINI_FLASH_MODEL=gemini-1.5-flash
GEMINI_PRO_MODEL=gemini-1.5-pro
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
SEMANTIC_CACHE_THRESHOLD=0.92
